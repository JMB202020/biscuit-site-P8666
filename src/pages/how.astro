        <p class="text-white/70 text-sm mb-1"><a href="tel:+441670814642" class="hover:text-white transition-colors">01670 814642</a></p>
        <p class="text-white/70 text-sm"><a href="mailto:ferndenecattery@yahoo.co.uk" class="hover:text-white transition-colors">ferndenecattery@yahoo.co.uk</a></p>
      </div>
      <div>
        <h3 class="font-extrabold mb-3">Pages</h3>
        <ul class="text-white/70 text-sm space-y-1">
          <li><a href="/P8666" class="hover:text-white transition-colors">Home</a></li>
          <li><a href="/P8666/why-choose-us" class="hover:text-white transition-colors">Why Choose Us</a></li>
          <li><a href="/P8666/how" class="hover:text-white transition-colors">How to Choose</a></li>
          <li><a href="/P8666/what-we-do" class="hover:text-white transition-colors">What We Do</a></li>
          <li><a href="/P8666/what-you-said" class="hover:text-white transition-colors">What You Said</a></li>
          <li><a href="/P8666/terms-and-tariff" class="hover:text-white transition-colors">Terms and Tariff</a></li>
          <li><a href="/P8666/gallery" class="hover:text-white transition-colors">Gallery</a></li>
          <li><a href="/P8666/contact" class="hover:text-white transition-colors">Contact Us</a></li>
        </ul>
      </div>
    </div>
    <div class="max-w-5xl mx-auto px-4 mt-8 pt-6 border-t border-white/10 flex flex-col sm:flex-row items-center justify-between gap-2 text-white/50 text-xs">
      <p>© 2014 Ferndene Cattery. Claire Janson. All rights reserved.</p>
      <p>This is a sample site built by <a href="https://biscuitweb.co.uk" class="hover:text-white transition-colors underline">Biscuit Web</a> to showcase our work.</p>
    </div>
  </footer>
</body>
</html>
